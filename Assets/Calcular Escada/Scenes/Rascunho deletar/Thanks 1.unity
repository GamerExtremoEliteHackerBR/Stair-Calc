  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: e3265ab4bf004d28a9537516768c1c75, type: 3}
    m_FontSize: 25
    m_FontStyle: 1
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 72
    m_Alignment: 4
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "Agradecimentos Especiais\r\n\r\n        N\xF3s da Gamer Extremo queremos
    expressar nossa mais profunda gratid\xE3o a todos voc\xEAs que utilizaram o {appName}.
    \r\n        Este aplicativo foi desenvolvido com dedica\xE7\xE3o, estudo e cuidado
    para oferecer uma ferramenta simples e \xFAtil \r\n        no c\xE1lculo e planejamento
    de escadas.\r\n\r\n        Agradecemos a cada usu\xE1rio que confiou no nosso
    trabalho, testou o app e nos ajudou a melhorar com feedbacks \r\n        e sugest\xF5es.
    O apoio de voc\xEAs \xE9 o que nos motiva a continuar criando solu\xE7\xF5es
    pr\xE1ticas e acess\xEDveis.\r\n\r\n        Nosso sincero agradecimento tamb\xE9m
    vai para todos que contribu\xEDram direta ou indiretamente para o \r\n       
    desenvolvimento do {appName}. O conhecimento compartilhado e a colabora\xE7\xE3o
    foram fundamentais \r\n        para transformar esta ideia em realidade.\r\n\r\n       
    Esperamos que o {appName} tenha sido \xFAtil no seu dia a dia, facilitando c\xE1lculos,
    economizando tempo \r\n        e trazendo mais praticidade para seus projetos.\r\n\r\n       
    E lembrem-se: essa \xE9 apenas uma das ferramentas que queremos compartilhar
    com voc\xEAs. \r\n        Fiquem atentos, pois novidades e melhorias vir\xE3o
    em breve!\r\n\r\n        Com gratid\xE3o,\r\n\r\n        Equipe Gamer Extremo"
