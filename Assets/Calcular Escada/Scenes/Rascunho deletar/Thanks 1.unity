      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: ab2cfde409d710b47b0b502877abb479, type: 3}
    m_FontSize: 28
    m_FontStyle: 1
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 72
    m_Alignment: 4
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "Agradecimentos Especiais\r\n\r\nN\xF3s da Gamer Extremo queremos expressar
    nossa mais sincera gratid\xE3o a todos voc\xEAs que embarcaram nessa jornada
    incr\xEDvel em Seven Crystals. Este projeto foi feito com muita dedica\xE7\xE3o
    e paix\xE3o, e sua participa\xE7\xE3o e apoio foram essenciais para que ele se
    tornasse realidade.\r\n\r\nAgradecemos a cada jogador que acreditou no nosso
    trabalho e nos acompanhou nessa aventura m\xE1gica no mundo de Lins. O seu tempo,
    feedback e entusiasmo nos inspiraram a dar o nosso melhor em cada detalhe do
    jogo.\r\n\r\nGostar\xEDamos de agradecer tamb\xE9m a todas as pessoas que colaboraram
    direta ou indiretamente para o desenvolvimento de Seven Crystals. Sem o talento,
    esfor\xE7o e dedica\xE7\xE3o de cada um, este projeto n\xE3o seria poss\xEDvel.\r\n\r\nEsperamos
    que voc\xEAs tenham se divertido tanto jogando quanto n\xF3s nos divertimos criando.\r\n\r\nEste
    \xE9 apenas o come\xE7o! Fiquem ligados para mais aventuras e desafios emocionantes
    no futuro.\r\n\r\nCom gratid\xE3o,\r\nEquipe Gamer Extremo"
